#include "main.h"

typedef struct
{
    int pin_num;       // GPIO引脚编号
    int direction;     // 0: 输入, 1: 输出
    int intr_type;     // 0: 电平触发, 1: 边沿触发
    int intr_polarity; // 0: 低电平或下降沿触发, 1: 高电平或上升沿触发
    int intr_enable;   // 0: 禁止中断, 1: 使能中断
} tGpioConfig;

static XGpioPs Gpio;               // GPIO实例
static XGpioPs_Config *GpioConfig; // GPIO配置实例

#define GPIO_DEVICE_ID XPAR_XGPIOPS_0_DEVICE_ID // GPIO设备ID
#define GPIO_INTERRUPT_ID XPAR_XGPIOPS_0_INTR   // GPIO中断ID

tGpioConfig g_sGpioConfigs[] = {
    {PS_LED1, 1, 0, 0}, // PS LED1，输出，不使用中断
    {PS_LED2, 1, 0, 0}, // PS LED2，输出，不使用中断
    {PS_KEY1, 0, 0, 1}, // PS KEY1，输入，下降沿触发中断
    {PS_KEY2, 0, 0, 1}, // PS KEY2，输入，下降沿触发中断

    {PL_KEY2, 0, 0, 1}, // PL KEY2，输入，下降沿触发中断
    {PL_LED1, 1, 0, 0}  // PL LED1，输出，不使用中断
};

// 根据引脚编号计算GPIO所在的bank
void gpio_calculate_bank(int pin_num, int *bank)
{
    if (pin_num < 54)
    {
        *bank = pin_num / 32;
    }
    else
    {
        pin_num -= 54;              // 调整为emio编号
        *bank = 2 + (pin_num / 32); // emio从bank2开始
    }
}

// GPIO中断处理函数
void gpio_interrupt_handler(void *CallbackRef)
{
    XGpioPs *InstancePtr = (XGpioPs *)CallbackRef;

    // 处理GPIO中断，例如读取引脚状态并清除中断
    for (int i = 0; i < sizeof(g_sGpioConfigs) / sizeof(g_sGpioConfigs[0]); i++)
    {
        if (g_sGpioConfigs[i].intr_enable == 1)
        {
            // 检测引脚是否产生中断
            uint32_t intr_status = XGpioPs_IntrGetStatusPin(InstancePtr, g_sGpioConfigs[i].pin_num);
            if (intr_status != 0)
            {
                // 处理该引脚的中断，例如读取引脚状态
                uint32_t pin_state = XGpioPs_ReadPin(InstancePtr, g_sGpioConfigs[i].pin_num);
                printf("Interrupt on pin %d, state: %d\n", g_sGpioConfigs[i].pin_num, pin_state);

                // 清除中断
                XGpioPs_IntrClearPin(InstancePtr, g_sGpioConfigs[i].pin_num);
            }
        }
    }
}

// GPIO初始化函数
int gpio_init()
{
    int Status;

    // 初始化GPIO实例
    GpioConfig = XGpioPs_LookupConfig(XPAR_XGPIOPS_0_DEVICE_ID);
    assert(GpioConfig != NULL);
    Status = XGpioPs_CfgInitialize(&Gpio, GpioConfig, GpioConfig->BaseAddr);
    assert(Status == XST_SUCCESS);

    // 配置GPIO引脚
    for (int i = 0; i < sizeof(g_sGpioConfigs) / sizeof(g_sGpioConfigs[0]); i++)
    {
        int bank;
        gpio_calculate_bank(g_sGpioConfigs[i].pin_num, &bank);
        if (g_sGpioConfigs[i].direction == 1)
        {
            // 设置引脚为输出
            XGpioPs_SetDirectionPin(&Gpio, g_sGpioConfigs[i].pin_num, 1);
            // 输出初始状态为低电平
            XGpioPs_WritePin(&Gpio, g_sGpioConfigs[i].pin_num, 0);
            // 使能引脚的输出功能
            XGpioPs_SetOutputEnablePin(&Gpio, g_sGpioConfigs[i].pin_num, 1);
        }
        else
        {
            XGpioPs_SetDirectionPin(&Gpio, g_sGpioConfigs[i].pin_num, 0);
            if (g_sGpioConfigs[i].intr_enable == 1)
            {
                // 设置中断处理函数
                XScuGic_SetPriorityTriggerType(&InterruptController, GPIO_INTERRUPT_ID, 0xA0, 0x3);
                Status = XScuGic_Connect(&InterruptController, GPIO_INTERRUPT_ID, (Xil_InterruptHandler)gpio_interrupt_handler, &Gpio);
                assert(Status == XST_SUCCESS);

                // 配置GPIO中断
                XGpioPs_SetIntrType(&Gpio, bank, g_sGpioConfigs[i].intr_type, g_sGpioConfigs[i].intr_polarity, 1);

                // 使能GPIO中断
                XScuGic_Enable(&InterruptController, GPIO_INTERRUPT_ID);

                // 开启中断
                XGpioPs_IntrEnablePin(&Gpio, g_sGpioConfigs[i].pin_num);
            }
        }
    }

    return XST_SUCCESS;
}

// 设置PS LED状态
void set_ps_led(uint32_t led_num, uint32_t state)
{
    if (led_num == 1)
    {
        XGpioPs_WritePin(&Gpio, PS_LED1, state);
    }
    else if (led_num == 2)
    {
        XGpioPs_WritePin(&Gpio, PS_LED2, state);
    }
}

// 设置PL LED状态
void set_pl_led(uint32_t led_num, uint32_t state)
{
    if (led_num == 1)
    {
        XGpioPs_WritePin(&Gpio, PL_LED1, state);
    }
}
